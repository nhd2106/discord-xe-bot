# Discord Bot Token (lấy từ https://discord.com/developers/applications)
DISCORD_TOKEN=your_bot_token_here

# Discord Application ID
CLIENT_ID=your_client_id_here

# Discord Guild (Server) ID
GUILD_ID=your_guild_id_here

# Channel ID để bot gửi thông báo đăng ký xe (channel #xe-cong-ty)
BOOKING_CHANNEL_ID=your_channel_id_here

# Role ID của Hành chính (người có quyền duyệt)
ADMIN_ROLE_ID=your_admin_role_id_here

# Google Sheets ID (sẽ cập nhật sau khi có sheet)
SHEET_ID=your_google_sheet_id_here

# Google Service Account credentials (JSON string hoặc path tới file)
GOOGLE_SERVICE_ACCOUNT_EMAIL=clara-780@agent-454716.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY=your_private_key_here
